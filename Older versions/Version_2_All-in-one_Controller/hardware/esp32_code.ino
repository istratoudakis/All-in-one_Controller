  // Spotify Timestamps
  tft.setTextSize(2);
  tft.setTextColor(TFT_WHITE);
  tft.setCursor(250, 130);
  tft.print("0:00");
  tft.setCursor(410, 130);
  tft.print("0:00");

  // --- ΔΕΞΙ ΚΟΥΤΙ ΚΑΤΩ: DISCORD AREA (Blurple) ---
  tft.drawRect(238, 160, 242, 160, TFT_WHITE); 
  tft.fillRect(240, 162, 238, 156, BLURPLE);

  // Main Discord Identity Logo 
  tft.drawBitmap(260, 205, discord_logo, 64, 64, TFT_WHITE);

  // Status Logo (Undeafened by default)
  tft.drawBitmap(380, 220, undeafened, 32, 32, TFT_WHITE); 
}

// ==========================================
// SETUP
// ==========================================
void setup() {
  Serial.begin(115200);
  delay(1000); 
  Serial.println("--- STARTING BOOT ---");

  // --- ΠΡΟΣΘΗΚΗ: ΑΡΧΙΚΟΠΟΙΗΣΗ ΤΟΥ IO EXPANDER ---
  if (!mcp.begin_I2C()) {
    Serial.println("❌ ΣΦΑΛΜΑ: Το MCP23017 δεν βρέθηκε! (I2C Error)");
  } else {
    Serial.println("✅ MCP23017 Initialized!");
    // Ενεργοποιούμε το Pull-Up για το κουμπί 1
    mcp.pinMode(BTN_SPOT_TOGGLE, INPUT_PULLUP);
    mcp.pinMode(BTN_NEXT, INPUT_PULLUP);
    mcp.pinMode(BTN_PREV, INPUT_PULLUP);
  }

  tft.begin();
  tft.setRotation(1); 
  
  tft.fillScreen(TFT_WHITE); 
  delay(200);
  tft.fillScreen(TFT_BLACK); 
  delay(200);
  
  Serial.println("Display Initialized");
  drawBootScreen();
}

// ==========================================
// MAIN LOOP
// ==========================================
void loop() {

  // --- ΠΡΟΣΘΗΚΗ: ΔΙΑΒΑΣΜΑ ΚΟΥΜΠΙΩΝ ΑΠΟ ΤΟ MCP23017 ---
  bool currentSpotToggleState = mcp.digitalRead(BTN_SPOT_TOGGLE);
  
  // Αν το κουμπί μόλις πατήθηκε (από HIGH πήγε LOW)
  if (lastSpotToggleState == HIGH && currentSpotToggleState == LOW) {
    // Στέλνουμε το σήμα στη Python για να αλλάξει το Spotify
    Serial.println("<BTN:SPOT_TOGGLE>");
    delay(50); // Μικρή καθυστέρηση (Debounce) για να μην στείλει την εντολή 10 φορές
  }
  lastSpotToggleState = currentSpotToggleState;

  // --- ΔΙΑΒΑΣΜΑ ΚΟΥΜΠΙΟΥ: NEXT ---
  bool currentNextState = mcp.digitalRead(BTN_NEXT);
  if (lastNextState == HIGH && currentNextState == LOW) {
    // Εδώ βάζεις το δικό σου function ή το Serial.println
    Serial.println("<BTN:NEXT>"); 
    delay(50); // Debounce
  }
  lastNextState = currentNextState;


  // --- ΔΙΑΒΑΣΜΑ ΚΟΥΜΠΙΟΥ: PREVIOUS ---
  bool currentPrevState = mcp.digitalRead(BTN_PREV);
  if (lastPrevState == HIGH && currentPrevState == LOW) {
    // Εδώ βάζεις το δικό σου function ή το Serial.println
    Serial.println("<BTN:PREV>"); 
    delay(50); // Debounce
  }
  lastPrevState = currentPrevState;


  // --- TEXT ANIMATION (MARQUEE) ---
  if (connection_status == true && currentSong.length() > 11) {
    
    int waitTime = 300; 
    if (scrollIndex == 0) {
      waitTime = 1500; 
    }

    if (millis() - lastScrollTime > waitTime) {
      lastScrollTime = millis(); 
      
      tft.fillRect(250, 70, 210, 30, TFT_BLACK); 
      
      String visibleText = currentSong.substring(scrollIndex, scrollIndex + 11);
      
      tft.setTextSize(3);
      tft.setTextColor(TFT_WHITE);
      tft.setCursor(250, 70);
      tft.print(visibleText);

      scrollIndex++;
      
      if (scrollIndex > currentSong.length() - 11) {
        scrollIndex = 0; 
      }
    }
  }
  
  // --- SERIAL COMMUNICATION ---
  if (Serial.available() > 0) {
    
    String incomingMessage = Serial.readStringUntil('\n');
    incomingMessage.trim();
    
    // Unlock Screen
    if (connection_status == false) {
      if (incomingMessage == "<PC_OK>") {
        connection_status = true;      
        drawBootScreen();         
      }
    }
    
    delay(50); 

    // Spotify Progress Bar % Listener
    if (incomingMessage.startsWith("<SPOT_PERC:")) {
        String valueText = incomingMessage.substring(11, incomingMessage.indexOf('>'));
        int progress = valueText.toInt(); 
        int barWidth = map(progress, 0, 100, 0, 206); 

        tft.fillRect(252, 112, barWidth, 6, TFT_WHITE); 
        tft.fillRect(252 + barWidth, 112, 206 - barWidth, 6, TFT_BLACK); 
    }
    
    // Spotify Song Name Listener
    else if (incomingMessage.startsWith("<SPOT_INFO:")) {
      String newSong = incomingMessage.substring(11, incomingMessage.indexOf('>'));
      
      if (newSong.length() > 11) {
        newSong += "   ";
      }

      if (currentSong != newSong) {
        currentSong = newSong;
        scrollIndex = 0; 

        tft.fillRect(250, 70, 210, 30, TFT_BLACK); 
        tft.setTextSize(3);
        tft.setTextColor(TFT_WHITE);
        tft.setCursor(250, 70);

        if (currentSong.length() <= 11) {
          tft.print(currentSong); 
        }
      }
    }

    // Current Time Listener
    else if (incomingMessage.startsWith("<SPOT_POS:")) {
      String curTime = incomingMessage.substring(10, incomingMessage.indexOf('>'));
      
      tft.fillRect(250, 130, 60, 20, TFT_BLACK); 
      tft.setTextSize(2);
      tft.setTextColor(TFT_WHITE);
      tft.setCursor(250, 130);
      tft.print(curTime);
    }

    // Total Time Listener
    else if (incomingMessage.startsWith("<SPOT_DUR:")) {
      String maxTime = incomingMessage.substring(10, incomingMessage.indexOf('>'));
      
      tft.fillRect(410, 130, 60, 20, TFT_BLACK); 
      tft.setTextSize(2);
      tft.setTextColor(TFT_WHITE);
      tft.setCursor(410, 130); 
      tft.print(maxTime);
    }
    
    // PC Volume Listener
    else if (incomingMessage.startsWith("<VOL:")) {
        String valueText = incomingMessage.substring(5, incomingMessage.indexOf('>'));
        int volume = valueText.toInt(); 
        int barWidth = map(volume, 0, 100, 0, 136);

        tft.fillRect(72, 33, barWidth, 6, TFT_BLACK); 
        tft.fillRect(72 + barWidth, 33, 136 - barWidth, 6, TFT_WHITE); 
    } 
    
    // Mic Status Listener
    else if (incomingMessage.startsWith("<MIC:")) {
      String status = incomingMessage.substring(5, incomingMessage.indexOf('>'));
      
      tft.fillRect(20, 160, 60, 30, TFT_WHITE); 
      tft.fillRect(25, 120, 32, 32, TFT_WHITE); 

      tft.setTextSize(3);
      tft.setCursor(22, 165);

      if (status == "ON") {
        tft.drawBitmap(25, 120, microphone_unmuted, 32, 32, TFT_BLACK);
        tft.setTextColor(TFT_GREEN);
        tft.print("ON");
      } else {
        tft.drawBitmap(25, 120, microphone_muted, 32, 32, TFT_RED);
        tft.setTextColor(TFT_RED);
        tft.print("OFF");
      }
    }

    // Cam Status Listener
    else if (incomingMessage.startsWith("<CAM:")) {
      String status = incomingMessage.substring(5, incomingMessage.indexOf('>'));
      
      tft.fillRect(140, 160, 60, 30, TFT_WHITE); 
      tft.setTextSize(3);
      tft.setCursor(140, 165);

      if (status == "ON") {
        tft.setTextColor(TFT_GREEN);
        tft.print("ON");
      } else {
        tft.setTextColor(TFT_RED);
        tft.print("OFF");
      }
    }
    
    // Discord Status Listener
    else if (incomingMessage.startsWith("<DISC:")) {
      String status = incomingMessage.substring(6, incomingMessage.indexOf('>'));
      
      tft.fillRect(380, 220, 32, 32, BLURPLE); 

      if (status == "DEAF") {
        tft.drawBitmap(380, 220, deafened, 32, 32, TFT_RED);
      } else {
        tft.drawBitmap(380, 220, undeafened, 32, 32, TFT_WHITE);
      }
    }
  }
}