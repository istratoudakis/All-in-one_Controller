// ==========================================
// SCREEN DRAWING FUNCTIONS
// ==========================================

void drawBootScreen() {
  tft.fillScreen(TFT_BLACK); 
  
  if (connection_status == false) {
    tft.setTextColor(TFT_RED); 
    tft.setTextSize(3);             
    tft.setCursor(90, 60);         
    tft.print("Connection Status");

    tft.fillRect(100, 120, 280, 80, TFT_RED);
    tft.setTextColor(TFT_BLACK); 
    tft.setTextSize(3);              
    tft.setCursor(110, 145);          
    tft.print("NOT ESTABLISHED");
  } else {
    tft.setTextColor(TFT_GREEN); 
    tft.setTextSize(3);             
    tft.setCursor(80, 60);         
    tft.print("Connection Status");

    tft.fillRect(100, 120, 280, 80, TFT_GREEN);
    tft.setTextColor(TFT_WHITE); 
    tft.setTextSize(3);              
    tft.setCursor(140, 145);          
    tft.print("ESTABLISHED");
    delay(1000);
    drawMainScreen();
  }
}

void drawMainScreen() {
  tft.fillScreen(TFT_BLACK); 

  // --- ΑΡΙΣΤΕΡΟ ΚΟΥΤΙ: PC SYSTEM (Λευκό) ---
  tft.drawRect(0, 0, 238, 320, TFT_WHITE); 
  tft.fillRect(2, 2, 234, 316, TFT_WHITE);

  // Volume UI
  tft.drawBitmap(20, 20, volume_logo, 32, 32, TFT_BLACK);
  tft.drawRect(70, 31, 140, 10, TFT_BLACK); 

  // Mic UI (Defaults to UNMUTED)
  tft.drawBitmap(25, 120, microphone_unmuted, 32, 32, TFT_BLACK);
  tft.fillRect(20, 160, 50, 30, TFT_WHITE); 
  tft.setTextSize(3);
  tft.setTextColor(TFT_GREEN); 
  tft.setCursor(22, 165);
  tft.print("ON");

  // Cam UI
  tft.drawBitmap(145, 120, cam_logo, 32, 32, TFT_BLACK);
  tft.fillRect(140, 160, 60, 30, TFT_WHITE);
  tft.setTextColor(TFT_RED);
  tft.setCursor(140, 165);
  tft.print("OFF");

  // --- ΔΕΞΙ ΚΟΥΤΙ ΠΑΝΩ: MULTIMEDIA (Μαύρο) ---
  tft.drawRect(238, 0, 242, 160, TFT_WHITE); 
  tft.fillRect(240, 2, 238, 156, TFT_BLACK);

  // Spotify UI
  tft.drawBitmap(250, 20, spotify_logo, 32, 32, TFT_GREEN);
